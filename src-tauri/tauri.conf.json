{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rotation Lock",
  "version": "0.1.0",
  "identifier": "dev.dylogamin.rotationlock",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rotation Lock",
        "width": 440,
        "height": 720,
        "minWidth": 380,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.ico"]
  }
}
